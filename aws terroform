Subnet:

terraform import aws_subnet.public_a subnet-08e0b90890f9a53d0
terraform import aws_subnet.public_b subnet-0edf8530fcd5025b0

terraform import aws_subnet.private_a subnet-05f89a63f1ff7a877
terraform import aws_subnet.private_b subnet-027bb3384153579df

IGW:

terraform import aws_internet_gateway.main igw-0dc2c4c441b7526ce

NAT:

terraform import aws_nat_gateway.main nat-16d2816d6ede4ba56

Route Table:

terraform import aws_route_table.public rtb-08bc9dc6ab2cfc9fe

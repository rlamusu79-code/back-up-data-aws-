1. Login AWS

Cek kredensial masih aktif:

aws sts get-caller-identity --no-cli-pager

Harus muncul:

{
  "Account": "195163394391",
  "Arn": "arn:aws:sts::..."
}
2. Buat Folder Backup
mkdir D:\backup-aws
cd D:\backup-aws

Struktur:

backup-aws/
├── main.tf
├── vpc.tf
├── security.tf
├── alb.tf
├── ecs.tf
├── outputs.tf
├── variables.tf
└── terraform.tfstate
3. Buat Provider Terraform

main.tf

terraform {
  required_providers {
    aws = {
      source = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}
4. Tulis Resource yang Ada di AWS

Contoh yang sudah kamu backup:

VPC
resource "aws_vpc" "main" {
  cidr_block           = "10.1.0.0/16"
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = "vpc-latihan-cc-2026"
  }
}
Public Subnet
resource "aws_subnet" "public_a" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.1.1.0/24"
  availability_zone       = "us-east-1a"
  map_public_ip_on_launch = true
}
Private Subnet
resource "aws_subnet" "private_a" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "10.1.11.0/24"
  availability_zone = "us-east-1a"
}
Internet Gateway
resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id
}
NAT Gateway
resource "aws_nat_gateway" "main" {
  allocation_id = "eipalloc-xxxxxxxx"
  subnet_id     = aws_subnet.public_a.id
}
Route Table Public
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }
}
Route Table Private
resource "aws_route_table" "private" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.main.id
  }
}
Security Group ALB
resource "aws_security_group" "alb" {
  name        = "sc-alb-latihan-cc-2026"
  description = "ALB Security Group"
  vpc_id      = aws_vpc.main.id
}
Security Group ECS
resource "aws_security_group" "ecs" {
  name        = "sc-ecs-latihan-cc-2026"
  description = "ECS Security Group"
  vpc_id      = aws_vpc.main.id
}
Security Group DB
resource "aws_security_group" "db" {
  name        = "sc-db-latihan-cc-2026"
  description = "Database Security Group"
  vpc_id      = aws_vpc.main.id
}
